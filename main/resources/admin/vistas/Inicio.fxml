            <Button fx:id="botonUsuarios" layoutX="246.0" layoutY="306.0" mnemonicParsing="false" onAction="#verUsuarios" prefHeight="30.0" prefWidth="120.0" style="-fx-background-color: rgb(25, 135, 84); -fx-background-radius: 10px;" text="Ver Usuarios" textFill="#070606">
