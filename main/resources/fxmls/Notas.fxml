         </graphic></Button>
      <Button fx:id="botonArchivar" layoutX="553.0" layoutY="509.0" mnemonicParsing="false" onAction="#archivarNota" prefHeight="30.0" prefWidth="86.0" style="-fx-background-color: #4FC3F7; -fx-background-radius: 10px;" text="Archivar" textFill="#070606">
