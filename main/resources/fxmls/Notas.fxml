<AnchorPane id="AnchorPane" prefHeight="577.0" prefWidth="814.0" style="-fx-background-color: rgb(205, 235, 232);" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ieslapuebla.bloc.controladores.NotasController">
