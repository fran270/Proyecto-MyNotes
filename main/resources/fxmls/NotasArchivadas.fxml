<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Menu?>
<?import javafx.scene.control.MenuBar?>
<?import javafx.scene.control.MenuItem?>
<?import javafx.scene.control.SeparatorMenuItem?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>
<?import javafx.scene.text.Font?>

<AnchorPane id="AnchorPane" prefHeight="421.0" prefWidth="732.0" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.ieslapuebla.bloc.controladores.NotasArchivadasController">
   <children>
      <Pane prefHeight="53.0" prefWidth="735.0" style="-fx-background-color: rgb(63, 188, 192);">
         <children>
            <Label fx:id="opcion1" layoutX="267.0" layoutY="17.0" onMouseClicked="#volverInicio" prefHeight="18.0" prefWidth="61.0" text="INICIO" textFill="#070606" textOverrun="WORD_ELLIPSIS">
               <font>
                  <Font name="Microsoft JhengHei UI Bold" size="14.0" />
               </font>
            </Label>
            <MenuBar fx:id="opcion2" layoutX="337.0" layoutY="12.0" prefHeight="30.0" prefWidth="87.0" style="-fx-background-color: rgb(63, 188, 192);">
               <menus>
                  <Menu mnemonicParsing="false" style="-fx-color: gray; -fx-font-weight: bold; -fx-font-size: 14px;" text="NOTAS">
                     <items>
                        <MenuItem mnemonicParsing="false" onAction="#verNotas" text="Listado de Notas" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#importarNota" text="Importar Nota" />
                        <SeparatorMenuItem mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#verNotasArchivadas" text="Notas Archivadas" />
                     </items>
                  </Menu>
               </menus>
            </MenuBar>
            <Label fx:id="opcion3" layoutX="436.0" layoutY="18.0" onMouseClicked="#verPapelera" prefHeight="18.0" prefWidth="70.0" text="PAPELERA" textFill="#070606">
               <font>
                  <Font name="Microsoft JhengHei UI Bold" size="14.0" />
               </font>
            </Label>
            <MenuBar layoutX="655.0" layoutY="10.0" prefHeight="37.0" prefWidth="45.0" style="-fx-background-radius: 10px; -fx-background-color: rgb(63, 188, 192);">
               <menus>
                  <Menu mnemonicParsing="false" style="-fx-background-radius: 6px;">
                     <items>
                        <MenuItem fx:id="usuarioConectado" mnemonicParsing="false" />
                        <MenuItem mnemonicParsing="false" onAction="#cerrarSesion" text="Cerrar Sesión" />
                     </items>
                     <graphic>
                        <ImageView fitHeight="29.0" fitWidth="37.0" pickOnBounds="true" preserveRatio="true">
                           <image>
                              <Image url="@../images/icono_usuario.png" />
                           </image>
                        </ImageView>
                     </graphic>
                  </Menu>
               </menus>
            </MenuBar>
            <ImageView fitHeight="40.0" fitWidth="176.0" layoutX="14.0" layoutY="9.0" pickOnBounds="true" preserveRatio="true">
               <image>
                  <Image url="@../images/Logo%20MyNotes.png" />
               </image>
            </ImageView>
         </children>
      </Pane>
      <Button fx:id="botonDesarchivar" layoutX="605.0" layoutY="153.0" mnemonicParsing="false" onMouseClicked="#desarchivarNota" prefHeight="25.0" prefWidth="93.0" text="Desarchivar" />
      <Label layoutY="409.0" prefHeight="31.0" prefWidth="735.0" style="-fx-background-color: rgb(63, 188, 192);" />
      <TableView fx:id="notasArchivadas" layoutX="79.0" layoutY="114.0" prefHeight="279.0" prefWidth="499.0">
        <columns>
          <TableColumn fx:id="titulo" prefWidth="141.0" text="Nombre" />
          <TableColumn fx:id="contenido" prefWidth="254.0" text="Contenido" />
            <TableColumn prefWidth="103.0" text="Botones" />
        </columns>
      </TableView>
      <Label alignment="CENTER" contentDisplay="CENTER" layoutX="262.0" layoutY="70.0" prefHeight="35.0" prefWidth="194.0" text="NOTAS ARCHIVADAS">
         <font>
            <Font name="Dubai Bold" size="19.0" />
         </font>
      </Label>
   </children>
</AnchorPane>
